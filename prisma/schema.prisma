generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id             String   @id @default(uuid())
  situation      String
  priceRange     String
  employment     String
  downPayment    String
  creditScore    String
  
  // Dynamic fields for specific campaigns
  campaign       String   @default("general")
  timeline       String?
  location       String?
  rawAnswers     Json?
  
  // Contact Info
  firstName      String
  lastName       String
  email          String
  phone          String
  street         String?
  city           String?
  state          String?
  
  // Chat Data
  chatTranscript Json?

  status         String   @default("NEW") // NEW, CONTACTED, SOLD
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relationship to Lender
  lenderId       String?
  lender         Lender?  @relation(fields: [lenderId], references: [id], onDelete: SetNull)
}

model Lender {
  id             String   @id @default(uuid())
  authUserId     String?  @unique
  firstName      String?
  lastName       String?
  companyName    String?
  companyAddress String?
  nmls           String?
  phone          String?
  email          String   @unique
  stripeId       String?
  isActive       Boolean  @default(true)
  isAdmin        Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  leads          Lead[]
}
